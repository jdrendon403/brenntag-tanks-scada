# ══════════════════════════════════════════════════════════
#  Producción — copiar a .env.prod y completar los valores
#  NUNCA commitear .env.prod al repositorio
# ══════════════════════════════════════════════════════════

# ── PLC Modbus ─────────────────────────────────────────────
PLC_HOST=192.168.1.100
PLC_PORT=502
MOCK_MODBUS=false
# false = orden ABCD (defecto); true = orden CDAB (segundo PLC con palabras invertidas)
MODBUS_WORD_SWAP=false

# ── MongoDB ─────────────────────────────────────────────────
MONGO_USER=admin
MONGO_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO
MONGODB_DB=scada_tanks
# URI con credenciales — debe coincidir con MONGO_USER y MONGO_PASSWORD
MONGODB_URI=mongodb://admin:CAMBIAR_POR_PASSWORD_SEGURO@db_scada:27017/scada_tanks?authSource=admin

# ── Autenticación JWT ────────────────────────────────────────
AUTH_USER=admin
AUTH_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO
AUTH_SECRET=CAMBIAR_POR_SECRETO_ALEATORIO_LARGO

# ── Aplicación ──────────────────────────────────────────────
POLLING_INTERVAL=1.0
LOG_LEVEL=WARNING

# ── Red ─────────────────────────────────────────────────────
HTTP_PORT=80
